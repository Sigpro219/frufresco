  {
    "key": "b2b_page_content",
    "value": "{\"badge\":\"Exclusivo HORECA e Institucional Bogotá , Girardot, Melgar y Anapoima\",\"title\":\"Tu Operación Merece \\n Lo Mejor del Campo\",\"description\":\"Únete a los +500 restaurantes, hoteles, casinos y comedores que ya compran sin intermediarios. Calidad estandarizada, trazabilidad y precios fijos para tu volumen.\",\"benefits\":[{\"icon\":\"🚀\",\"title\":\"Entrega AM\",\"desc\":\"Todo listo antes de abrir cocina.\"},{\"icon\":\"💰\",\"title\":\"Precios Justos\",\"desc\":\"Ahorro directo sin intermediarios.\"},{\"icon\":\"🥕\",\"title\":\"Frescura Total\",\"desc\":\"Cosechado ayer, entregado hoy.\"},{\"icon\":\"💳\",\"title\":\"Crédito B2B\",\"desc\":\"Paga a 15 o 30 días fácil.\"}]}",
